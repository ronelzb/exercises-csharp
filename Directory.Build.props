<Project>
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <SatelliteResourceLanguages>en;es</SatelliteResourceLanguages>

    <ProductVersion>1.0.0</ProductVersion>
    <ProductVersionFull>1.0.0.0</ProductVersionFull>

    <!-- Apply versions to .NET projects -->
    <VersionPrefix>$(ProductVersion)</VersionPrefix>
    <InformationalVersion>$(ProductVersion)</InformationalVersion>
    <AssemblyVersion>$(ProductVersionFull)</AssemblyVersion>
    <FileVersion>$(ProductVersionFull)</FileVersion>

    <RuntimeIdentifiers>win-x64;linux-x64;linux-arm64</RuntimeIdentifiers>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <!-- Code styling -->
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <!-- NU5048: Package missing readme -->
    <NoWarn>$(NoWarn);1591;NU1701;NU5048</NoWarn>
    <!-- Suppress IDE0055 (formatting) in Release - cross-platform formatter inconsistencies -->
    <NoWarn Condition="'$(Configuration)' == 'Release'">$(NoWarn);IDE0055</NoWarn>
  </PropertyGroup>
</Project>
